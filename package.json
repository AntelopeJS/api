{
  "name": "@antelopejs/api",
  "version": "1.0.0",
  "description": "A flexible API module that implements the API interfaces of antelopejs with HTTP and WebSocket support",
  "keywords": [
    "antelopejs",
    "api",
    "http",
    "websocket",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/api.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "ajs project run -w -p playground",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "test": "pnpm run build && ajs module test ."
  },
  "antelopeJs": {
    "implements": [
      "@antelopejs/interface-api",
      "@antelopejs/interface-api-util"
    ],
    "test": "src/test/antelope.test.ts",
    "defaultConfig": {
      "servers": [
        {
          "protocol": "http",
          "host": "localhost",
          "port": 8080
        }
      ]
    }
  },
  "dependencies": {
    "@antelopejs/interface-api": "^0.0.2",
    "@antelopejs/interface-api-util": "^0.0.2",
    "@antelopejs/interface-core": "^0.0.2",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/node": "^22.19.15",
    "@types/sinon": "^21.0.0",
    "@types/ws": "^8.18.1",
    "release-it": "^19.2.4",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.1.3",
    "sinon": "^21.0.3",
    "typescript": "^5.9.3"
  }
}
